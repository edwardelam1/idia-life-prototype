# Copy this file to .env to override defaults locally.
# .env is gitignored — your changes stay on your machine.

# Set to "false" to load the app's UI from local dist/ instead of Lovable preview URL.
# Useful when testing OAuth flows that need deep links to route back to your code,
# or when you want to test the exact bundle that will ship to production.
#
# Default (when this variable is unset or anything else): Lovable URL is used.
# CAPACITOR_USE_LOVABLE=false
